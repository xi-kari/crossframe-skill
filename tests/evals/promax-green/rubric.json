      "relation_to_proposition",
      "judgment_strength",
      "option_kind_ranking",
      "option_semantic_ranking",
      "normative_selection_basis_sha256"
    ],
    "required_within_run_integrity": [
      "semantic_key_sha256_recomputed",
      "central_statement_sha256_recomputed_and_stable",
      "full_exact_v8_option_record_sha256_recomputed",
      "option_semantic_sha256_recomputed_without_option_id",
      "no_action_option_id_resolves_uniquely",
      "selection_review_wrapper_recomputed_and_normative_basis_normalized",
      "red_team_before_after_bind_actual_artifacts"
    ],
    "frozen_pair_context": {
      "analysis_object": "远程办公对组织信任的影响",
      "factual_material": [],
      "time_window": "未指定",
      "evidence_cutoff": "2026-07-23T00:00:00+08:00"
    },
    "frozen_pair_context_sha256": "cd695ac14bb9a69c694261d3c3eb0b444291e4560a33651c7b6a748845150967",
    "required_judgment_strength_drift": 0
  },
  "acceptance": {
    "all_exercised_minimum_metrics_meet_threshold": true,
    "all_exercised_maximum_metrics_meet_threshold": true,
    "unexercised_metrics_are_explicitly_recorded": true,
    "paired_stability_passes_for_every_required_model": true,
    "raw_output_hashes_and_skill_tree_hashes_verify": true,
    "deterministic_regression_suite_passes": true
  }
}
