{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossframe.local/schemas/promax-claim-path-graph.schema.json",
  "title": "CrossFrame ProMax v8 claim and path graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "run_id",
    "source_snapshot_sha256",
    "central_claim_id",
    "central_claim_cycle",
    "claims",
    "mechanisms",
    "path_nodes",
    "path_edges",
    "forecast_conditions",
    "choice_boundary",
    "updated_at"
  ],
  "properties": {
    "schema_id": {"const": "crossframe.promax.v8.claim-path-graph"},
    "schema_version": {"const": 1},
    "run_id": {"$ref": "promax-common.schema.json#/$defs/runId"},
    "source_snapshot_sha256": {"$ref": "promax-common.schema.json#/$defs/v8SnapshotSha256"},
    "central_claim_id": {"$ref": "promax-common.schema.json#/$defs/claimId"},
    "central_claim_cycle": {"$ref": "#/$defs/centralClaimCycle"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/claim"}
    },
    "mechanisms": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/mechanism"}
    },
    "path_nodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/pathNode"}
    },
    "path_edges": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/pathEdge"}
    },
    "forecast_conditions": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"},
    "choice_boundary": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
    "updated_at": {"$ref": "promax-common.schema.json#/$defs/timestamp"}
  },
  "$defs": {
    "centralClaimCycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["central_claim_id", "initial_judgment", "strongest_attack", "revision", "counterfactual", "withdrawal_conditions"],
      "properties": {
        "central_claim_id": {"$ref": "promax-common.schema.json#/$defs/claimId"},
        "initial_judgment": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "strongest_attack": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "revision": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "counterfactual": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "withdrawal_conditions": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "statement", "claim_type", "evidence_refs", "concept_ids", "confidence", "authorization_ceiling"],
      "properties": {
        "claim_id": {"$ref": "promax-common.schema.json#/$defs/claimId"},
        "statement": {"type": "string", "minLength": 2, "pattern": "\\S"},
        "claim_type": {"enum": ["factual", "structural", "mechanistic", "path", "forecast", "normative", "authorization"]},
        "evidence_refs": {"$ref": "promax-common.schema.json#/$defs/stringArray"},
        "concept_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "promax-common.schema.json#/$defs/conceptId"}
        },
        "confidence": {"enum": ["low", "medium", "high", "indeterminate"]},
        "authorization_ceiling": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"}
      }
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism_id", "label", "claim_ids", "distinguishing_conditions"],
      "properties": {
        "mechanism_id": {"type": "string", "pattern": "^MECH-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "label": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "promax-common.schema.json#/$defs/claimId"}
        },
        "distinguishing_conditions": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"}
      }
    },
    "pathNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "label", "node_type", "trigger_conditions", "early_signals", "reverse_signals", "stop_conditions"],
      "properties": {
        "node_id": {"type": "string", "pattern": "^NODE-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "label": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "node_type": {"enum": ["state", "event", "decision", "outcome"]},
        "trigger_conditions": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"},
        "early_signals": {"$ref": "promax-common.schema.json#/$defs/stringArray"},
        "reverse_signals": {"$ref": "promax-common.schema.json#/$defs/stringArray"},
        "stop_conditions": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"}
      }
    },
    "pathEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "from_node_id", "to_node_id", "mechanism_ids", "condition", "outcome_writeback"],
      "properties": {
        "edge_id": {"type": "string", "pattern": "^EDGE-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "from_node_id": {"type": "string", "pattern": "^NODE-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "to_node_id": {"type": "string", "pattern": "^NODE-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "mechanism_ids": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"},
        "condition": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "outcome_writeback": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"}
      }
    }
  }
}
