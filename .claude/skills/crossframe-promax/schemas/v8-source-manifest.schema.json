{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossframe.local/schemas/v8-source-manifest.schema.json",
  "title": "CrossFrame ProMax v8 source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "framework_version",
    "snapshot_sha256",
    "paragraph_count",
    "non_whitespace_chars",
    "table_count",
    "section_count",
    "generator",
    "source_ranges",
    "files"
  ],
  "properties": {
    "schema_id": {"const": "crossframe.promax.v8.source-manifest"},
    "schema_version": {"const": 1},
    "framework_version": {"const": "v8.0"},
    "snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "paragraph_count": {"const": 3863},
    "non_whitespace_chars": {"const": 155721},
    "table_count": {"const": 117},
    "section_count": {"const": 16},
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "sha256"],
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "source_ranges": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "paragraph_start", "paragraph_end", "table_start", "table_end"],
        "properties": {
          "file": {"type": "string", "pattern": "^(?:00-source-envelope|(?:0[1-9]|1[0-6])-[a-z0-9-]+)\\.md$"},
          "paragraph_start": {"$ref": "#/$defs/paragraph_anchor"},
          "paragraph_end": {"$ref": "#/$defs/paragraph_anchor"},
          "table_start": {"oneOf": [{"$ref": "#/$defs/table_anchor"}, {"type": "null"}]},
          "table_end": {"oneOf": [{"$ref": "#/$defs/table_anchor"}, {"type": "null"}]}
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 138,
      "maxItems": 138,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size"],
        "properties": {
          "path": {"type": "string", "pattern": "^v8-full-source/"},
          "sha256": {"$ref": "#/$defs/sha256"},
          "size": {"type": "integer", "minimum": 1}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "paragraph_anchor": {"type": "string", "pattern": "^V8-P[0-9]{4}$"},
    "table_anchor": {"type": "string", "pattern": "^V8-T[0-9]{3}$"}
  }
}
