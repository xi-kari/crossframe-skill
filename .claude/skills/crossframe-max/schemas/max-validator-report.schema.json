{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CrossFrame Max Validator Report v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version",
    "run_id",
    "profile",
    "run_mode",
    "execution_state",
    "artifact_state",
    "incomplete_reasons",
    "input_validation_state",
    "validation_state",
    "run_contract_sha256",
    "manifest_sha256",
    "artifact_sha256",
    "final_label",
    "passed",
    "generated_at",
    "validators",
    "errors"
  ],
  "properties": {
    "report_version": {
      "const": "v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "artifact-run",
        "complete",
        "design-review",
        "blocked"
      ]
    },
    "run_mode": {
      "enum": [
        "max-artifact-run",
        "max-complete",
        "max-design-review",
        "max-blocked/progress"
      ]
    },
    "execution_state": {
      "enum": [
        "pending",
        "running",
        "blocked",
        "finished"
      ]
    },
    "artifact_state": {
      "enum": [
        "absent",
        "partial",
        "core_complete",
        "strict_complete"
      ]
    },
    "incomplete_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_validation_state": {
      "enum": [
        "not_run",
        "failed",
        "passed"
      ]
    },
    "validation_state": {
      "enum": [
        "failed",
        "passed"
      ]
    },
    "run_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "manifest_sha256": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifact_sha256": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    },
    "final_label": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_error"
      }
    }
  },
  "$defs": {
    "validation_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_id",
        "validator",
        "error_type",
        "severity",
        "artifact",
        "field",
        "message",
        "affected_phase",
        "repair_action",
        "downstream_reset",
        "final_output_allowed"
      ],
      "properties": {
        "error_id": {
          "type": "string",
          "minLength": 1
        },
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "error_type": {
          "enum": [
            "missing_artifact",
            "invalid_json",
            "route_registry_closure_failed",
            "route_plan_mismatch",
            "concept_registry_missing",
            "concept_source_anchor_mismatch",
            "concept_contract_missing",
            "source_paragraph_not_in_read_range",
            "claim_missing_audit",
            "claim_missing_concept_hit",
            "evidence_chain_missing",
            "counterevidence_missing",
            "external_search_required",
            "essay_too_short",
            "dossier_section_too_thin",
            "repeated_filler",
            "forbidden_output_present",
            "missing_claim_or_source_reference",
            "full_source_incomplete",
            "unrepairable_repository_state",
            "retry_budget_exhausted",
            "runtime_state_conflict",
            "invalid_validation_transition",
            "profile_mismatch",
            "manifest_state_mismatch",
            "false_complete_claim",
            "stale_or_false_validation_claim",
            "premature_final_claim",
            "artifact_semantic_thinness",
            "missing_template_heading",
            "duplicate_identifier",
            "cross_reference_mismatch",
            "design_review_closure_failed"
          ]
        },
        "severity": {
          "enum": [
            "error",
            "warning"
          ]
        },
        "artifact": {
          "type": "string"
        },
        "field": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "affected_phase": {
          "type": "string"
        },
        "repair_action": {
          "type": "string"
        },
        "downstream_reset": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_output_allowed": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "passed"
        ],
        "properties": {
          "passed": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "validation_state": {
            "const": "passed"
          },
          "errors": {
            "maxItems": 0
          }
        }
      },
      "else": {
        "properties": {
          "validation_state": {
            "const": "failed"
          },
          "errors": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile"
        ],
        "properties": {
          "profile": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "properties": {
          "manifest_sha256": {
            "type": "null"
          },
          "artifact_sha256": {
            "maxProperties": 0
          }
        }
      },
      "else": {
        "properties": {
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "artifact_sha256": {
            "minProperties": 1
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile",
          "passed"
        ],
        "properties": {
          "profile": {
            "const": "complete"
          },
          "passed": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "const": "max-complete"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile",
          "passed"
        ],
        "properties": {
          "profile": {
            "const": "design-review"
          },
          "passed": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "const": "max-design-review"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile",
          "passed"
        ],
        "properties": {
          "profile": {
            "const": "blocked"
          },
          "passed": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "const": "max-blocked/progress"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile",
          "passed",
          "incomplete_reasons"
        ],
        "properties": {
          "profile": {
            "const": "artifact-run"
          },
          "passed": {
            "const": true
          },
          "incomplete_reasons": {
            "minItems": 1
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "pattern": "^max-artifact-incomplete:.+"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "profile",
          "passed",
          "incomplete_reasons"
        ],
        "properties": {
          "profile": {
            "const": "artifact-run"
          },
          "passed": {
            "const": true
          },
          "incomplete_reasons": {
            "maxItems": 0
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "const": "max-artifact-run-valid"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "passed"
        ],
        "properties": {
          "passed": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "final_label": {
            "pattern": "^max-validation-failed:(artifact-run|complete|design-review|blocked):[a-z0-9_]+$"
          }
        }
      }
    }
  ]
}
