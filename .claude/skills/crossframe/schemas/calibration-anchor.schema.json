{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CrossFrame V5 DLC Calibration Anchor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "construct_id",
    "name_zh",
    "definition",
    "not_this",
    "neighbor_concepts",
    "anchors",
    "minimum_evidence",
    "high_responsibility_upgrade_conditions",
    "misuse_risks",
    "withdrawal_condition",
    "v5_source_anchors",
    "worksheets",
    "schema_fields"
  ],
  "properties": {
    "construct_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name_zh": {
      "type": "string",
      "minLength": 1
    },
    "definition": {
      "type": "string",
      "minLength": 1
    },
    "not_this": {
      "type": "string",
      "minLength": 1
    },
    "neighbor_concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "anchors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["0", "1", "2", "3", "4"],
      "properties": {
        "0": {
          "type": "string",
          "minLength": 1
        },
        "1": {
          "type": "string",
          "minLength": 1
        },
        "2": {
          "type": "string",
          "minLength": 1
        },
        "3": {
          "type": "string",
          "minLength": 1
        },
        "4": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "minimum_evidence": {
      "type": "string",
      "minLength": 1
    },
    "high_responsibility_upgrade_conditions": {
      "type": "string",
      "minLength": 1
    },
    "misuse_risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "withdrawal_condition": {
      "type": "string",
      "minLength": 1
    },
    "v5_source_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "worksheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "schema_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
