{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossframe.local/schemas/v8-contract-map.schema.json",
  "title": "CrossFrame ProMax v8 authored contract map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "framework_version", "snapshot_sha256", "contract_count", "semantic_coverage_sha256", "contracts"],
  "properties": {
    "schema_id": {"const": "crossframe.promax.v8.contract-map"},
    "schema_version": {"const": 1},
    "framework_version": {"const": "v8.0"},
    "snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "contract_count": {"const": 3},
    "semantic_coverage_sha256": {"$ref": "#/$defs/sha256"},
    "contracts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contract_id", "path", "sha256", "scope", "concept_ids", "required_semantic_pointers", "unbound_semantic_pointers", "bindings"],
        "properties": {
          "contract_id": {"enum": ["v8_actor_state_contracts", "v8_multicircle_contracts", "v8_simulation_forecast_contracts"]},
          "path": {"type": "string", "pattern": "^concept-contracts/[a-z-]+\\.json$"},
          "sha256": {"$ref": "#/$defs/sha256"},
          "scope": {"type": "string", "minLength": 1},
          "concept_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"$ref": "#/$defs/concept_id"}
          },
          "required_semantic_pointers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^/"}
          },
          "unbound_semantic_pointers": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["json_pointer", "reason_code", "runtime_requirement"],
              "properties": {
                "json_pointer": {"type": "string", "pattern": "^/(?:[^~/]|~[01])*(?:/(?:[^~/]|~[01])*)*$"},
                "reason_code": {"const": "no_distinct_v8_canonical_concept"},
                "runtime_requirement": {"const": "read_authored_contract_pointer_directly"}
              }
            }
          },
          "bindings": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["json_pointer", "concept_id", "binding_role", "source_anchors"],
              "properties": {
        "json_pointer": {"type": "string", "pattern": "^/(?:[^~/]|~[01])*(?:/(?:[^~/]|~[01])*)*$"},
                "concept_id": {"$ref": "#/$defs/concept_id"},
                "binding_role": {"enum": ["domain", "definition", "enum_set", "enum_value", "record_schema", "required_field", "example", "constraint", "forbidden", "action_ceiling"]},
                "source_anchors": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["anchor_id", "source_file"],
                    "properties": {
                      "anchor_id": {"type": "string", "pattern": "^V8-P[0-9]{4}$"},
                      "source_file": {"type": "string", "pattern": "^(?:0[1-9]|1[0-6])-[a-z0-9-]+\\.md$"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "concept_id": {"type": "string", "pattern": "^V8-CANON-[A-Z0-9][A-Z0-9-]*$"}
  }
}
