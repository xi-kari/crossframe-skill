{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossframe.local/schemas/promax-red-team-report.schema.json",
  "title": "CrossFrame ProMax adversarial red-team report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "run_id", "source_snapshot_sha256", "central_claim_id", "attacks", "stability_checks", "revision_summary", "completed_at"],
  "properties": {
    "schema_id": {"const": "crossframe.promax.v8.red-team-report"},
    "schema_version": {"const": 1},
    "run_id": {"$ref": "promax-common.schema.json#/$defs/runId"},
    "source_snapshot_sha256": {"$ref": "promax-common.schema.json#/$defs/v8SnapshotSha256"},
    "central_claim_id": {"$ref": "promax-common.schema.json#/$defs/claimId"},
    "attacks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/attack"}
    },
    "stability_checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stabilityCheck"}
    },
    "revision_summary": {"$ref": "promax-common.schema.json#/$defs/nonemptyStringArray"},
    "completed_at": {"$ref": "promax-common.schema.json#/$defs/timestamp"}
  },
  "$defs": {
    "attack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attack_id", "attack_class", "target_id", "challenge", "counterevidence_refs", "strongest_counterposition", "result", "revision", "position_impact"],
      "properties": {
        "attack_id": {"type": "string", "pattern": "^ATTACK-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "attack_class": {
          "enum": [
            "object_reification",
            "boundary_error",
            "scale_transformation_error",
            "personality_overinference",
            "circle_reification",
            "stage_model_misuse",
            "baseline_leakage",
            "path_storytelling",
            "uncalibrated_probability",
            "prediction_authorization_leakage",
            "inaction_zero_cost",
            "decision_irrelevant_counterexample"
          ]
        },
        "target_id": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"},
        "challenge": {"type": "string", "minLength": 2, "pattern": "\\S"},
        "counterevidence_refs": {"$ref": "promax-common.schema.json#/$defs/stringArray"},
        "strongest_counterposition": {"type": "string", "minLength": 2, "pattern": "\\S"},
        "result": {"enum": ["survived", "survived_with_revision", "rejected", "unresolved"]},
        "revision": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "position_impact": {"enum": ["none", "low", "medium", "high", "decisive"]}
      }
    },
    "stabilityCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_pair_id", "pro_prompt_sha256", "anti_prompt_sha256", "position_drift", "explanation"],
      "properties": {
        "prompt_pair_id": {"type": "string", "pattern": "^PAIR-[A-Za-z0-9][A-Za-z0-9._-]*(?![\\s\\S])"},
        "pro_prompt_sha256": {"$ref": "promax-common.schema.json#/$defs/sha256"},
        "anti_prompt_sha256": {"$ref": "promax-common.schema.json#/$defs/sha256"},
        "position_drift": {"enum": ["none", "justified_by_evidence", "unjustified"]},
        "explanation": {"$ref": "promax-common.schema.json#/$defs/nonemptyString"}
      }
    }
  }
}
